---
import CapitalEntrySequence from '../components/home/CapitalEntrySequence.astro';
import DecisionBar from '../components/home/DecisionBar.astro';
import HeroPerimeter from '../components/home/HeroPerimeter.astro';
import InquiryPreparationFile from '../components/home/InquiryPreparationFile.astro';
import LedgerCompare from '../components/home/LedgerCompare.astro';
import SectionRule from '../components/home/SectionRule.astro';
import SeparatedLedger from '../components/home/SeparatedLedger.astro';
import VehicleReadinessDocket from '../components/home/VehicleReadinessDocket.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const deliveryBreak = {
  left: {
    title: 'Known',
    items: ['Evidence', 'Public concern', 'Institutional interest', 'Public-value need'],
  },
  right: {
    title: 'Not yet executable',
    items: ['Lawful authority', 'Counterparty', 'Payment route', 'Delivery owner', 'Correction rights'],
  },
};

const capitalEntrySteps = [
  { number: '01', label: 'Lawful route', detail: 'Authority exists before capital discipline enters the file.' },
  { number: '02', label: 'Clear counterparty', detail: 'Obligation is carried by an accountable institutional actor.' },
  { number: '03', label: 'Payment logic', detail: 'Who pays, for what, and under which standards is visible.' },
  { number: '04', label: 'Public-value obligation', detail: 'The structure owes more than performance to a balance sheet.' },
  { number: '05', label: 'Stop / correction rights', detail: 'The work can pause, remediate, redirect, or exit responsibly.' },
];

const docketItems = [
  {
    title: 'Vehicle design',
    body: 'The vehicle is designed around a defined component, not the wider legitimacy of the System.',
  },
  {
    title: 'Execution mandate',
    body: 'The mandate names authority, route, obligation, limit, and the conditions under which action may proceed.',
  },
  {
    title: 'Ring-fenced operating structures',
    body: 'Ledgers, liabilities, public-value duties, and protected layers remain visibly separated.',
  },
  {
    title: 'Counterparty diligence',
    body: 'The file tests who benefits, who controls, who pays, and who can be held accountable.',
  },
  {
    title: 'Procurement discipline',
    body: 'Adoption must withstand fairness, compliance, anti-corruption, and public accountability review.',
  },
  {
    title: 'Milestone and stop-rule logic',
    body: 'Delivery is tied to cadence, auditability, incident escalation, correction, and responsible exit.',
  },
];

const perimeterComparison = {
  inside: [
    'Ring-fenced vehicle',
    'Mandate',
    'Contracted execution',
    'Public-value operating platform',
    'Purposeful media vehicle with cleared controls',
  ],
  outside: [
    'The Equilibrium System as an investment product',
    'PRF public-good layers',
    'Protected human spaces',
    'Civic coalition spaces',
    'Evidence conclusions',
    'Sponsor rewards',
    'Lobbying or influence work',
  ],
};

const proofCards = [
  {
    title: 'Narrow structure',
    body: 'Start with a component small enough to be governed, tested, corrected, and explained.',
  },
  {
    title: 'Clean firewall',
    body: 'Keep public-good finance, protected spaces, evidence work, and execution economics separated.',
  },
  {
    title: 'Auditable record',
    body: 'Build a file that can survive sovereign, fiduciary, operator, auditor, and public-interest scrutiny.',
  },
];

const separatedLedger = {
  left: {
    title: 'PRF',
    summary: 'Public-good, prevention, repair, readiness',
    items: ['Prevention', 'Repair', 'Trust infrastructure', 'Readiness', 'Safeguarding', 'Measurement'],
  },
  right: {
    title: 'EQVII',
    summary: 'Vehicle, mandate, payment, execution, audit',
    items: ['Ring-fenced vehicle', 'Contracted execution', 'Payment logic', 'Counterparty obligation', 'Auditability', 'Correction rights'],
  },
};

const decisions = [
  { label: 'Proceed' },
  { label: 'Conditions' },
  { label: 'Pause' },
  { label: 'Redirect' },
  { label: 'Decline' },
];
---

<BaseLayout
  title="Capital under public-value constraint"
  titleTemplate="entityFirst"
  description="Ring-fenced vehicles, execution mandates, and accountable delivery discipline within The Equilibrium System. Public orientation only; not an offering or transaction approval."
>
  <HeroPerimeter
    eyebrow="EQVII Holdings / The Equilibrium System"
    headline="Capital enters only where the perimeter can hold."
    subline="EQVII structures the lawful execution layer of public-value work: ring-fenced vehicles, mandates, operating platforms, and accountable delivery structures where legitimacy, counterparties, payment logic, obligations, and correction rights can withstand scrutiny."
    primaryLabel="Explore the perimeter"
    secondaryLabel="Prepare an inquiry file"
  />

  <SectionRule
    id="delivery-break"
    eyebrow="The delivery break"
    heading="Diagnosed is not delivered."
    lead="A public-value problem can be understood, urgent, and institutionally acknowledged while still lacking the structure that can carry it: lawful authority, counterparty, payment route, delivery owner, audit discipline, correction rights, and responsible exit."
  >
    <LedgerCompare left={deliveryBreak.left} right={deliveryBreak.right} />
  </SectionRule>

  <SectionRule
    id="eqvii-answer"
    eyebrow="EQVII's answer"
    heading="EQVII builds the execution perimeter."
    lead="The perimeter is the difference between responsible participation and blurred advantage. It defines what may be structured, who carries obligation, where payment sits, what remains outside, and when the work must pause, redirect, or stop."
    tone="panel"
  >
    <CapitalEntrySequence steps={capitalEntrySteps} />
  </SectionRule>

  <SectionRule
    id="what-eqvii-builds"
    eyebrow="What EQVII builds"
    heading="Structures for work that can carry discipline."
  >
    <VehicleReadinessDocket items={docketItems} />
  </SectionRule>

  <SectionRule
    id="perimeter-rule"
    eyebrow="The perimeter rule"
    heading="The System may be financeable. It is not itself the investment product."
    lead="Investability exists only through defined vehicles, mandates, contracts, or execution structures. Protected spaces, public-good layers, evidence conclusions, coalition trust, and civic legitimacy do not transfer into a return case."
    tone="panel"
  >
    <div class="comparison-list comparison-list--premium">
      <article>
        <h3>Inside the perimeter</h3>
        <ul>
          {perimeterComparison.inside.map((item) => <li>{item}</li>)}
        </ul>
      </article>
      <article>
        <h3>Outside the perimeter</h3>
        <ul>
          {perimeterComparison.outside.map((item) => <li>{item}</li>)}
        </ul>
      </article>
    </div>
  </SectionRule>

  <SectionRule
    id="phase-one-posture"
    eyebrow="Phase 1 posture"
    heading="Proof before scale."
    lead="EQVII should begin with one or two narrow, legible structures. The first task is not breadth. It is a record strong enough to survive sovereign, fiduciary, operator, auditor, and public-interest scrutiny."
  >
    <div class="record-grid">
      {
        proofCards.map((card, index) => (
          <article class="record-card">
            <span>{String(index + 1).padStart(2, '0')}</span>
            <strong>{card.title}</strong>
            <p>{card.body}</p>
          </article>
        ))
      }
    </div>
  </SectionRule>

  <SectionRule
    id="prf-eqvii-boundary"
    eyebrow="PRF / EQVII boundary"
    heading="Same challenge. Separate ledger."
    lead="PRF may support prevention, repair, trust infrastructure, readiness, safeguarding, or measurement. EQVII may structure the distinct execution component that can honestly carry lawful payment logic, counterparty obligation, auditability, and correction rights. The layers may coordinate. They may not merge."
    tone="panel"
  >
    <SeparatedLedger left={separatedLedger.left} right={separatedLedger.right} rule="Same challenge. Separate ledger." />
  </SectionRule>

  <SectionRule
    id="governance"
    eyebrow="Governance"
    heading="The covenant decides whether the work proceeds."
    lead="Governance must be able to say more than yes."
  >
    <DecisionBar items={decisions} />
  </SectionRule>

  <InquiryPreparationFile
    heading="Bring the file, not the pitch."
    body="A routed inquiry begins with classification: what is the component, who has authority, what payment logic exists, what obligation is visible, what remains outside the perimeter, and what must be refused or redirected."
    note="An inquiry does not create authorization, endorsement, transaction status, investment access, procurement status, capital commitment, priority, or public permission to claim association."
  />
</BaseLayout>
