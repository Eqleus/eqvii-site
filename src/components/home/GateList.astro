---
interface Gate {
  number: string;
  label: string;
}

interface Props {
  gates: Gate[];
}

const { gates } = Astro.props;
---

<ol class="gate-list">
  {
    gates.map((gate) => (
      <li>
        <span>{gate.number}</span>
        <strong>{gate.label}</strong>
      </li>
    ))
  }
</ol>

<style>
  .gate-list {
    border-top: 1px solid var(--color-rule-strong);
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .gate-list li {
    align-items: center;
    border-bottom: 1px solid var(--color-rule);
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 3.25rem 1fr;
    min-height: 4.25rem;
    padding: var(--space-3) var(--space-4);
  }

  .gate-list li:nth-child(odd) {
    border-right: 1px solid var(--color-rule);
  }

  .gate-list span {
    color: var(--color-steel);
    font-size: 0.8rem;
    font-variant-numeric: tabular-nums;
  }

  .gate-list strong {
    font-size: 1rem;
    font-weight: 650;
  }

  @media (max-width: 42rem) {
    .gate-list {
      grid-template-columns: 1fr;
    }

    .gate-list li:nth-child(odd) {
      border-right: 0;
    }
  }
</style>
