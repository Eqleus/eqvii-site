---
interface Props {
  id?: string;
  eyebrow?: string;
  heading: string;
  lead?: string;
  tone?: 'default' | 'panel' | 'severe';
}

const { id, eyebrow, heading, lead, tone = 'default' } = Astro.props;
const className = ['section-rule', `section-rule--${tone}`].join(' ');
---

<section id={id} class={className} aria-labelledby={id ? `${id}-heading` : undefined}>
  <div class="container section-rule__inner">
    <header class="section-rule__header">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h2 id={id ? `${id}-heading` : undefined}>{heading}</h2>
      {lead && <p>{lead}</p>}
    </header>
    <div class="section-rule__body">
      <slot />
    </div>
  </div>
</section>

<style>
  .section-rule {
    border-bottom: 1px solid var(--color-rule);
    padding-block: var(--space-9);
  }

  .section-rule--panel {
    background: var(--color-panel);
  }

  .section-rule--severe {
    background: var(--color-text);
    color: var(--color-surface);
  }

  .section-rule__inner {
    display: grid;
    gap: var(--space-8);
    grid-template-columns: minmax(16rem, 0.74fr) minmax(0, 1.26fr);
  }

  .section-rule__header {
    border-top: 2px solid currentColor;
    min-width: 0;
    padding-top: var(--space-4);
  }

  .section-rule__body {
    min-width: 0;
  }

  .section-rule__header h2 {
    font-size: 2.25rem;
    line-height: 1.1;
    margin: var(--space-5) 0 0;
  }

  .section-rule__header p:not(.eyebrow) {
    color: var(--color-muted);
    font-size: 1.04rem;
    line-height: 1.65;
    margin: var(--space-5) 0 0;
  }

  .section-rule--severe .section-rule__header p:not(.eyebrow),
  .section-rule--severe .eyebrow {
    color: var(--color-severe-muted);
  }

  @media (max-width: 58rem) {
    .section-rule__inner {
      grid-template-columns: 1fr;
    }

    .section-rule__header h2 {
      font-size: 1.9rem;
    }
  }
</style>
