---
interface Gate {
  number: string;
  label: string;
  detail?: string;
}

interface Props {
  gates: Gate[];
}

const { gates } = Astro.props;
---

<ol class="gate-matrix">
  {
    gates.map((gate) => (
      <li>
        <span>{gate.number}</span>
        <div>
          <strong>{gate.label}</strong>
          {gate.detail && <p>{gate.detail}</p>}
        </div>
      </li>
    ))
  }
</ol>

<style>
  .gate-matrix {
    background: var(--color-rule);
    display: grid;
    gap: 1px;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    list-style: none;
    margin: 0;
    padding: 1px;
  }

  .gate-matrix li {
    background: var(--color-surface);
    display: grid;
    gap: var(--space-4);
    grid-template-columns: 3rem 1fr;
    min-height: 5rem;
    min-width: 0;
    padding: var(--space-4);
  }

  .gate-matrix span {
    color: var(--color-steel);
    font-size: 0.78rem;
    font-variant-numeric: tabular-nums;
  }

  .gate-matrix strong {
    display: block;
    font-size: 1rem;
    line-height: 1.3;
  }

  .gate-matrix p {
    color: var(--color-muted);
    line-height: 1.55;
    margin: var(--space-2) 0 0;
  }

  @media (max-width: 42rem) {
    .gate-matrix {
      grid-template-columns: 1fr;
    }
  }
</style>
