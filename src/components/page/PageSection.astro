---
interface Props {
  id?: string;
  eyebrow?: string;
  heading: string;
  lead?: string;
  tone?: 'default' | 'panel' | 'severe';
}

const { id, eyebrow, heading, lead, tone = 'default' } = Astro.props;
const className = ['page-section', `page-section--${tone}`].join(' ');
---

<section id={id} class={className} aria-labelledby={id ? `${id}-heading` : undefined}>
  <div class="container page-section__inner">
    <header class="page-section__header">
      {eyebrow && <p class="eyebrow">{eyebrow}</p>}
      <h2 id={id ? `${id}-heading` : undefined}>{heading}</h2>
      {lead && <p>{lead}</p>}
    </header>
    <div class="page-section__body">
      <slot />
    </div>
  </div>
</section>

<style>
  .page-section {
    border-bottom: 1px solid var(--color-rule);
    padding-block: var(--space-8);
  }

  .page-section--panel {
    background: var(--color-panel);
  }

  .page-section--severe {
    background: var(--color-text);
    color: var(--color-surface);
  }

  .page-section__inner {
    display: grid;
    gap: var(--space-7);
    grid-template-columns: minmax(15rem, 0.68fr) minmax(0, 1.32fr);
  }

  .page-section__header,
  .page-section__body {
    min-width: 0;
  }

  .page-section__header {
    border-top: 2px solid currentColor;
    padding-top: var(--space-4);
  }

  .page-section h2 {
    font-size: 2.05rem;
    line-height: 1.12;
    margin: var(--space-5) 0 0;
  }

  .page-section__header p:not(.eyebrow) {
    color: var(--color-muted);
    font-size: 1.02rem;
    line-height: 1.68;
    margin: var(--space-5) 0 0;
  }

  .page-section--severe .page-section__header p:not(.eyebrow),
  .page-section--severe .eyebrow {
    color: var(--color-severe-muted);
  }

  @media (max-width: 58rem) {
    .page-section__inner {
      grid-template-columns: 1fr;
    }

    .page-section h2 {
      font-size: 1.78rem;
    }
  }

  @media (max-width: 36rem) {
    .page-section__header,
    .page-section__body {
      max-width: 21rem;
    }

    .page-section h2 {
      font-size: 1.58rem;
      max-width: 13ch;
    }
  }
</style>
