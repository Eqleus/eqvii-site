---
interface Props {
  tone?: 'default' | 'severe';
}

const { tone = 'default' } = Astro.props;
---

<aside class:list={['rule-note', `rule-note--${tone}`]}>
  <slot />
</aside>

<style>
  .rule-note {
    border-left: 2px solid var(--color-steel);
    color: var(--color-muted);
    font-size: 1.02rem;
    line-height: 1.7;
    margin-top: var(--space-5);
    padding-left: var(--space-4);
  }

  .rule-note :global(p) {
    margin: 0;
  }

  .rule-note--severe {
    border: 1px solid color-mix(in srgb, var(--color-surface) 25%, transparent);
    color: var(--color-surface);
    font-size: 1.25rem;
    margin-top: 0;
    padding: var(--space-5);
  }
</style>
